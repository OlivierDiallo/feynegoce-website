# SQLite is the default — leave DATABASE_URL unset and the app will use
# investor-dashboard/prisma/dev.db (created automatically by `npm install`).
# Override only if you want to point at a managed Postgres / MySQL instance.
# DATABASE_URL=file:./investor-dashboard/prisma/dev.db

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY=24h

# Bcrypt
BCRYPT_ROUNDS=10

# First admin bootstrap — NO PASSWORD HERE.
# On first run, the server creates this admin without a password and emails them
# an activation link. They set their own password through the link.
ADMIN_EMAIL=diallo982@gmail.com
ADMIN_NAME=Olivier Diallo

# SMTP — REQUIRED for invite/reset emails to be delivered.
# Use a Hostinger email account you've created in the email panel.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@feynegoce.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Feynegoce Dashboard" <notifications@feynegoce.com>

# App
FRONTEND_URL=https://feynegoce.com
NODE_ENV=production
PORT=3000
