# PostgreSQL on Railway — copy your Railway connection string here
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY=24h

# Bcrypt
BCRYPT_ROUNDS=12

# SMTP (Hostinger email or any SMTP provider)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@feynegoce.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Feynegoce Dashboard" <notifications@feynegoce.com>

# App
FRONTEND_URL=https://feynegoce.com
NODE_ENV=production
PORT=3001
