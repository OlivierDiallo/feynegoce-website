# MySQL on Hostinger — get credentials from Hostinger panel > Databases > MySQL
DATABASE_URL=mysql://u123456789_user:password@localhost:3306/u123456789_feynegoce

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY=24h

# Bcrypt
BCRYPT_ROUNDS=10

# Initial admin account (created on first startup)
ADMIN_EMAIL=admin@feynegoce.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Olivier Diallo

# SMTP (optional — Hostinger email or any SMTP provider)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@feynegoce.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Feynegoce Dashboard" <notifications@feynegoce.com>

# App
FRONTEND_URL=https://feynegoce.com
NODE_ENV=production
PORT=3000
