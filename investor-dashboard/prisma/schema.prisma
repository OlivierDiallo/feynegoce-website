generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid()) @db.VarChar(36)
  email             String   @unique @db.VarChar(255)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  name              String   @db.VarChar(255)
  role              String   @db.VarChar(20) // "admin" | "investor"
  notificationPrefs String   @default("{}") @map("notification_prefs") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  splits    ShipmentInvestorSplit[]
  auditLogs AuditLog[]

  @@map("users")
}

model Product {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shipments Shipment[]

  @@map("products")
}

model Shipment {
  id              String    @id @default(uuid()) @db.VarChar(36)
  productId       String    @map("product_id") @db.VarChar(36)
  reference       String    @unique @db.VarChar(50)
  origin          String    @db.VarChar(255)
  destination     String    @db.VarChar(255)
  quantity        Int
  quantityUnit    String    @map("quantity_unit") @db.VarChar(50)
  costOfGoods     Decimal   @map("cost_of_goods") @db.Decimal(12, 2)
  currency        String    @default("EUR") @db.VarChar(10)
  targetMarginPct Decimal   @map("target_margin_pct") @db.Decimal(5, 2)
  eta             DateTime? @db.Date
  status          String    @default("pending") @db.VarChar(30)
  trackingNumber  String?   @map("tracking_number") @db.VarChar(100)
  notes           String?   @db.Text
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  product    Product                 @relation(fields: [productId], references: [id])
  expenses   ShipmentExpense[]
  sales      ShipmentSale[]
  splits     ShipmentInvestorSplit[]
  milestones ShipmentMilestone[]

  @@index([productId])
  @@map("shipments")
}

model ShipmentExpense {
  id          String   @id @default(uuid()) @db.VarChar(36)
  shipmentId  String   @map("shipment_id") @db.VarChar(36)
  category    String   @db.VarChar(100)
  description String?  @db.Text
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_expenses")
}

model ShipmentInvestorSplit {
  id         String   @id @default(uuid()) @db.VarChar(36)
  shipmentId String   @map("shipment_id") @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  splitPct   Decimal  @map("split_pct") @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([shipmentId, userId])
  @@index([userId])
  @@map("shipment_investor_splits")
}

model ShipmentSale {
  id              String   @id @default(uuid()) @db.VarChar(36)
  shipmentId      String   @map("shipment_id") @db.VarChar(36)
  customerName    String   @map("customer_name") @db.VarChar(255)
  quantitySold    Int      @map("quantity_sold")
  sellingPrice    Decimal  @map("selling_price") @db.Decimal(12, 2)
  actualMarginPct Decimal  @map("actual_margin_pct") @db.Decimal(5, 2)
  marginDelta     Decimal  @map("margin_delta") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_sales")
}

model ShipmentMilestone {
  id            String   @id @default(uuid()) @db.VarChar(36)
  shipmentId    String   @map("shipment_id") @db.VarChar(36)
  milestoneType String   @map("milestone_type") @db.VarChar(30)
  occurredAt    DateTime @map("occurred_at")
  notes         String?  @db.Text
  source        String   @default("manual") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_milestones")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  action     String   @db.VarChar(20)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(36)
  oldValues  String?  @map("old_values") @db.Text
  newValues  String?  @map("new_values") @db.Text
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@map("audit_log")
}
